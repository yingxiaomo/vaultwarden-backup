# --------------------------------------------
# Vaultwarden Backup — .gitignore
# --------------------------------------------

# 临时脚本 / 临时产物
*.tmp
*.swp
*.bak
_fix_*
fix_bugs*

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 操作系统文件
Thumbs.db
.DS_Store
Desktop.ini

# IDE / 编辑器
.vscode/
.idea/
*.sublime-*

# Docker 本地数据
/vw_data/

# 本地备份目录
backups/

# Rclone 本地配置副本
rclone_config/

# 环境变量导出文件
env.sh
vaultwarden-backup.exe
