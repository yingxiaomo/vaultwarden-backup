# --------------------------------------------
# Vaultwarden Backup — .gitignore
# --------------------------------------------

# 临时文件
*.tmp
*.swp
*.bak
_fix_*
fix_bugs*

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# 环境文件
.env
env.sh

# 操作系统文件
Thumbs.db
.DS_Store
Desktop.ini

# IDE / 编辑器
.vscode/
.idea/
*.sublime-*

# Docker 本地数据
/vw_data/

# 本地备份目录
backups/

# Rclone 本地配置副本
rclone_config/

# 日志
logs/
*.log

# 构建产物
build/
dist/
*.egg-info/

# 虚拟环境
venv/
env/

# Docker
.dockerignore